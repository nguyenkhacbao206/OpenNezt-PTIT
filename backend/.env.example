# =============================================================================
# BACKEND CONFIG — copy file này thành `.env` rồi chỉnh:  cp .env.example .env
# =============================================================================
# Backend đọc cấu hình qua pydantic-settings (core/config.py). File `.env` thật
# bị gitignore — TUYỆT ĐỐI không commit secrets. Luôn giữ file này đồng bộ với
# `.env` (cùng danh sách biến, chỉ khác giá trị/secret).
#
# ----------------------------------------------------------------------------
# BẮT ĐẦU NHANH — chọn 1 trong 3 chế độ (DEFAULT_MODE):
#
#   1) mock    → CHẠY NGAY, không cần key, không cần model. Trả lời giả để test
#                luồng/UI. Người mới nên thử cái này đầu tiên.
#   2) cloud   → Dùng Groq (miễn phí). Chỉ cần điền GROQ_API_KEY bên dưới.
#                Khuyến nghị cho demo thật vì chất lượng cao, không cần GPU.
#   3) offline → Chạy 100% local bằng model tải về (không cần internet). Nặng,
#                cần tải model trước bằng các script trong tools/ (xem từng phần).
#
# Chạy backend:
#   python -m venv .venv && .venv\Scripts\Activate.ps1   # (Windows) hoặc: source .venv/bin/activate
#   pip install -r requirements.txt
#   uvicorn app.main:app --reload                        # http://localhost:8000
#   uvicorn app.main:app --host 0.0.0.0 --port 8000      # cho máy khác trong LAN truy cập (ghép cặp 2 máy)
#
# Kiểm tra: mở http://localhost:8000/  (health JSON) và http://localhost:8000/app (console test WS)
# =============================================================================


# --- Server ------------------------------------------------------------------
# Host: 0.0.0.0 = lắng nghe mọi card mạng (cần cho 2 máy LAN ghép cặp).
#       127.0.0.1 = chỉ máy này.
HOST=0.0.0.0
PORT=8000
# CORS: danh sách origin cách nhau bởi dấu phẩy. "*" là ổn cho dev local.
CORS_ORIGINS=*

# Chế độ pipeline mặc định: mock | cloud | offline  (xem "BẮT ĐẦU NHANH" ở trên)
# Có thể đổi giữa chừng qua sự kiện WS `config.update {mode}` — không cần restart.
DEFAULT_MODE=cloud

# Preload model local lúc startup (core/warmup.py) để người nói đầu tiên không
# phải chờ nạp NLLB/Whisper/Piper (~13s). Chạy nền, không chặn /ws, lỗi chỉ log.
# Chỉ có tác dụng ở mode=offline hoặc TTS_ENGINE=piper.
WARMUP_ON_STARTUP=true


# =============================================================================
# GROQ (dùng khi DEFAULT_MODE=cloud) — KHUYẾN NGHỊ CHO NGƯỜI MỚI
# =============================================================================
# 1 key Groq lo cả STT (Whisper) lẫn NMT (Llama). Lấy key MIỄN PHÍ tại:
#   https://console.groq.com/keys   (key bắt đầu bằng "gsk_...")
# Dán vào GROQ_API_KEY là đủ chạy. Nếu bỏ trống, cloud mode tự fallback về mock.
# Kiểm tra key hoạt động:  python tools/check_groq_key.py
GROQ_API_KEY=
GROQ_API_URL=https://api.groq.com/openai/v1
GROQ_STT_MODEL=whisper-large-v3
GROQ_NMT_MODEL=llama-3.3-70b-versatile
# (Nâng cao) Tách rate-limit bằng 2 key riêng cho STT và NMT (2 project/tài khoản
# Groq khác nhau). Để trống thì cả hai dùng chung GROQ_API_KEY ở trên.
GROQ_STT_API_KEY=
GROQ_NMT_API_KEY=


# =============================================================================
# TTS — đọc thành tiếng (TÁCH RỜI khỏi STT/NMT mode, luôn hoạt động)
# =============================================================================
# TTS_ENGINE:
#   edge  → Microsoft edge-tts online. MIỄN PHÍ, không cần key, giọng Việt+Anh
#           thật, tự phát cho cả web lẫn mobile. (MẶC ĐỊNH — cứ để yên là chạy.)
#   piper → Piper local, chạy OFFLINE. Cần cài package `piper-tts` + tải giọng:
#           python tools/download_piper_models.py   → lưu vào models/tts/{vi,en}
#           rồi set PIPER_MODELS_DIR bên dưới.
#   mock  → âm thanh giả (chỉ để test).
TTS_ENGINE=edge
EDGE_VOICE_VI=vi-VN-HoaiMyNeural
EDGE_VOICE_EN=en-US-AriaNeural
# Chỉ dùng khi TTS_ENGINE=piper:
# PIPER_MODELS_DIR=models/tts
# PIPER_LENGTH_SCALE=1.0

# (Nâng cao) Chỉ dùng nếu bạn tự wire CloudTTSProvider — edge/piper KHÔNG dùng.
TTS_API_KEY=
TTS_API_URL=


# =============================================================================
# OFFLINE — STT (chỉ dùng khi DEFAULT_MODE=offline)
# =============================================================================
# Chọn engine nhận dạng giọng nói qua STT_ENGINE:
#   whisper    → Faster-Whisper đa ngôn ngữ, tự nhận diện tiếng (dễ nhất, MẶC ĐỊNH)
#   sherpa     → sherpa-onnx, 1 model/ngôn ngữ: zipformer VI + zipformer EN
#                (nguồn phải khai báo rõ tiếng, KHÔNG auto-detect)
#   phowhisper → PhoWhisper cho tiếng Việt + Whisper cho tiếng Anh (VI chuẩn nhất,
#                nên có GPU để chạy real-time)
STT_ENGINE=whisper

# Runtime của Faster-Whisper (dùng chung cho whisper + phowhisper):
#   Máy thường: cpu / int8 (an toàn, mặc định).
#   Có GPU:     cuda / float16 (nhanh hơn nhiều, cần cho PhoWhisper-large real-time).
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
# Kích thước model cho STT_ENGINE=whisper:
#   tiny/base (nhanh) .. small (mặc định) .. medium/large-v3 (chính xác nhất, nên có GPU)
STT_MODEL_SIZE=small

# Chỉ dùng khi STT_ENGINE=phowhisper (bỏ qua nếu khác). Build model VI trước:
#   python tools/prepare_phowhisper.py   → rồi trỏ PHOWHISPER_MODEL_DIR vào thư mục ra.
PHOWHISPER_MODEL_DIR=
WHISPER_EN_MODEL=small

# Chỉ dùng khi STT_ENGINE=sherpa (bỏ qua nếu khác). Tải model trước:
#   python tools/download_sherpa_models.py
SHERPA_MODELS_DIR=models
SHERPA_USE_INT8=false
SHERPA_NUM_THREADS=2
SHERPA_DECODING_METHOD=greedy_search


# =============================================================================
# OFFLINE — NMT (dịch máy, chỉ dùng khi DEFAULT_MODE=offline)
# =============================================================================
# Chọn engine dịch qua NMT_ENGINE:
#   nllb    → CTranslate2 + NLLB-200 (nhẹ, nhanh, real-time trên CPU; MẶC ĐỊNH)
#   seallm  → gọi server chat local kiểu OpenAI (Ollama/vLLM) chạy SeaLLM
#   sealion → SEA-LION v4 (AI Singapore) qua API api.sea-lion.ai
# LƯU Ý: sealion là engine DUY NHẤT cũng dùng được ở DEFAULT_MODE=cloud
# (Groq Whisper STT + SEA-LION dịch). Ở mode=offline nó vẫn cần internet.
NMT_ENGINE=nllb

# --- Khi NMT_ENGINE=nllb ---
# Build model trước:  python tools/prepare_nllb.py
# Để trống → offline mode sẽ báo lỗi rõ ràng (cloud mode không bị ảnh hưởng).
OFFLINE_NMT_MODEL_DIR=
# Device/độ chính xác cho NLLB (CTranslate2):
#   cpu/int8 an toàn; cuda/float16 nhanh & chuẩn hơn nhiều nếu có GPU.
#   Beam 5 rẻ trên GPU; để thấp trên CPU cho nhanh.
OFFLINE_NMT_DEVICE=cpu
OFFLINE_NMT_COMPUTE_TYPE=int8
OFFLINE_NMT_BEAM_FINAL=4

# --- Khi NMT_ENGINE=seallm ---
# Phải chạy server model trước — xem backend/ollama/Modelfile:
#   ollama create seallm-v3 -f Modelfile
LOCAL_NMT_API_URL=http://localhost:11434/v1
LOCAL_NMT_MODEL=seallm-v3
LOCAL_NMT_API_KEY=ollama

# --- Khi NMT_ENGINE=sealion ---
# Lấy key miễn phí ở https://playground.sea-lion.ai rồi kiểm tra bằng:
#   python tools/check_sealion_key.py
# CẢNH BÁO: free tier ~10 request/phút. Mỗi cụm VAD = 1 request, nên một cuộc
# họp nói liên tục SẼ chạm limit (backend emit `error`, không rớt kết nối).
# Muốn bỏ giới hạn: tự host SEA-LION v4 GGUF rồi trỏ SEALION_API_URL vào đó:
#   ollama pull aisingapore/Gemma-SEA-LION-v4-27B-IT     # ~16GB RAM/VRAM
#   ollama pull aisingapore/Gemma-SEA-LION-v4-4B-VL      # nhẹ, chạy được CPU
#   SEALION_API_URL=http://localhost:11434/v1
#   SEALION_MODEL=aisingapore/Gemma-SEA-LION-v4-4B-VL
SEALION_API_URL=https://api.sea-lion.ai/v1
SEALION_API_KEY=
SEALION_MODEL=aisingapore/Qwen-SEA-LION-v4.5-27B-IT
