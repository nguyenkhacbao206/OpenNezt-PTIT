# Backend configuration (pydantic-settings). The real .env is gitignored —
# never commit secrets. Keep this file and .env.example in sync.

# --- Server ---
HOST=0.0.0.0
PORT=8000
# CORS (comma-separated). "*" is fine for local dev.
CORS_ORIGINS=*

# Default pipeline mode: mock | cloud | offline
DEFAULT_MODE=cloud

# --- Offline STT engine (mode=offline) ---
# whisper -> Faster-Whisper (multilingual, auto-detect)
# sherpa  -> sherpa-onnx per-language: gipformer (VI) + zipformer-en (EN)
STT_ENGINE=whisper
# sherpa-only settings (ignored when STT_ENGINE=whisper):
SHERPA_MODELS_DIR=models
SHERPA_USE_INT8=false
SHERPA_NUM_THREADS=2
SHERPA_DECODING_METHOD=greedy_search

# --- Groq (cloud STT via Whisper + bidirectional NMT via Llama) ------
# Get a free key at https://console.groq.com/keys (starts with gsk_...).
# One key powers both transcription (Whisper) and translation (Llama).
GROQ_API_KEY=
GROQ_API_URL=https://api.groq.com/openai/v1
GROQ_STT_MODEL=whisper-large-v3
GROQ_NMT_MODEL=llama-3.3-70b-versatile
# Optional: split rate limits with a separate key per stage (2 different
# Groq projects/accounts). Leave blank to reuse GROQ_API_KEY.
GROQ_STT_API_KEY=
GROQ_NMT_API_KEY=

# --- TTS (decoupled from STT/NMT mode) ---
# TTS_ENGINE: edge (online neural, free, real VN+EN — default) | piper | mock.
# edge-tts renders audio server-side so web AND mobile clients just play it.
# No API key needed for edge (uses Microsoft's free online endpoint).
TTS_ENGINE=edge
EDGE_VOICE_VI=vi-VN-HoaiMyNeural
EDGE_VOICE_EN=en-US-AriaNeural
# Piper (only if TTS_ENGINE=piper):
# PIPER_MODELS_DIR=models/tts
# PIPER_LENGTH_SCALE=1.0

# --- Cloud TTS vendor (only if you wire CloudTTSProvider; not used by edge) ---
TTS_API_KEY=
TTS_API_URL=

# --- Offline NMT (CTranslate2 + NLLB-200) ---
# Built by: python tools/prepare_nllb.py
# Unset -> offline mode NMT raises a clear error (cloud mode unaffected).
OFFLINE_NMT_MODEL_DIR=
