# ---- STT / model artifacts & recordings ----
# NOTE: keep comments on their OWN line. A trailing "# ..." comment on the same
# line as a pattern is treated as part of the pattern and silently disables it.
# generated markdown transcripts
transcripts/
# never commit captured/test audio (zero-retention)
*.wav
*.mp3
*.m4a
*.webm
# local model weights (Faster-Whisper / sherpa-onnx / NLLB / Piper)
models/
*.onnx
*.bin
*.ckpt

