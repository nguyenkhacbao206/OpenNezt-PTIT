# =============================================================================
# FRONTEND CONFIG (Expo / React Native) — file template, ĐƯỢC commit
# =============================================================================
# Trong Expo, CHỈ biến có tiền tố EXPO_PUBLIC_ mới lọt vào JS bundle.
# => Đây là cấu hình phía client, KHÔNG bao giờ đặt secret thật ở đây.
#
# CÁCH DÙNG cho người mới:
#   1) cp .env .env.local          # tạo bản override riêng của máy bạn
#   2) sửa EXPO_PUBLIC_WS_URL trong .env.local trỏ về backend (xem bên dưới)
#   3) npm install && npm start    # nhấn w=web, a=Android, i=iOS
# (.env.local bị gitignore, ghi đè .env — chỉnh trên đó, đừng sửa file này.)
# -----------------------------------------------------------------------------

# Base URL API REST (phần auth/template mặc định — pipeline dịch KHÔNG dùng cái này,
# nó chạy qua WebSocket bên dưới). Để nguyên nếu chưa có backend REST riêng.
EXPO_PUBLIC_API_URL=https://api.example.com

# Timeout request REST (mili-giây).
EXPO_PUBLIC_API_TIMEOUT=15000

# Môi trường chạy: development | staging | production
EXPO_PUBLIC_APP_ENV=development

# -----------------------------------------------------------------------------
# QUAN TRỌNG NHẤT — WebSocket của backend phiên dịch real-time (STT/NMT/TTS).
# Đây là thứ nối app tới backend. Chọn URL theo tình huống:
#   • Web/giả lập cùng máy với backend:  ws://localhost:8000/ws
#   • Điện thoại thật (Expo Go) hoặc ghép cặp 2 máy trong LAN:
#       dùng IP LAN của MÁY CHẠY BACKEND, ví dụ:  ws://192.168.1.15:8000/ws
#       (tìm IP: chạy `ipconfig` trên máy backend; mở firewall cho TCP 8000;
#        backend phải chạy với --host 0.0.0.0)
# Có thể đổi trực tiếp trong app (Demo1 → "Cài đặt backend"), nên đây chỉ là mặc định.
EXPO_PUBLIC_WS_URL=ws://localhost:8000/ws
