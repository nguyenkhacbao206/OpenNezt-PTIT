# ---------------------------------------------------------------------------
# Environment variables template.
# In Expo, only variables prefixed with EXPO_PUBLIC_ are exposed to the JS bundle.
# NEVER put real secrets here — this file is only a client-side configuration.
# Copy this file to `.env.local` for machine-specific overrides.
# ---------------------------------------------------------------------------

# Base URL of the backend API.
EXPO_PUBLIC_API_URL=https://api.example.com

# Request timeout in milliseconds.
EXPO_PUBLIC_API_TIMEOUT=15000

# Current runtime environment: development | staging | production
EXPO_PUBLIC_APP_ENV=development
